<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light dark" />
  <title>Informasi Details — BetSlip Insight</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --bg-soft: #eef3fa;
      --surface: rgba(255,255,255,.90);
      --surface-solid: #ffffff;
      --surface-muted: #f7f9fd;
      --text: #15213a;
      --muted: #68758d;
      --line: #e2e8f2;
      --line-strong: #d6deeb;
      --primary: #5b5cf0;
      --primary-2: #8d5cf6;
      --primary-3: #3f8cff;
      --primary-soft: #efefff;
      --success: #0f9d68;
      --success-soft: #e9f9f2;
      --warning: #c47a04;
      --warning-soft: #fff5df;
      --danger: #db4355;
      --danger-soft: #fff0f2;
      --info: #3478db;
      --info-soft: #eaf2ff;
      --shadow-sm: 0 8px 24px rgba(30,45,74,.07);
      --shadow-md: 0 18px 52px rgba(30,45,74,.11);
      --shadow-lg: 0 34px 90px rgba(20,31,55,.22);
      --radius-sm: 12px;
      --radius-md: 18px;
      --radius-lg: 26px;
    }

    html[data-theme="dark"] {
      --bg: #0d1320;
      --bg-soft: #111a2b;
      --surface: rgba(20,29,47,.90);
      --surface-solid: #151f33;
      --surface-muted: #1a263d;
      --text: #edf3ff;
      --muted: #9daac0;
      --line: #273650;
      --line-strong: #33435e;
      --primary: #8284ff;
      --primary-2: #a678ff;
      --primary-3: #5aa1ff;
      --primary-soft: #292b55;
      --success: #46d39a;
      --success-soft: #153a31;
      --warning: #f5bc59;
      --warning-soft: #41331d;
      --danger: #ff7181;
      --danger-soft: #45232b;
      --info: #7cb2ff;
      --info-soft: #203654;
      --shadow-sm: 0 8px 24px rgba(0,0,0,.20);
      --shadow-md: 0 18px 52px rgba(0,0,0,.28);
      --shadow-lg: 0 34px 90px rgba(0,0,0,.42);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      background:
        radial-gradient(circle at 10% 0%, rgba(91,92,240,.18), transparent 28%),
        radial-gradient(circle at 92% 8%, rgba(63,140,255,.13), transparent 26%),
        linear-gradient(180deg, var(--bg-soft), var(--bg));
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      transition: background .25s ease, color .25s ease;
    }

    button, input, select, textarea { font: inherit; }
    button { cursor: pointer; }
    button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible {
      outline: 3px solid rgba(91,92,240,.24);
      outline-offset: 2px;
    }

    .app {
      width: min(1580px, calc(100% - 28px));
      margin: 18px auto 44px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
      padding: 13px 16px;
      border: 1px solid rgba(255,255,255,.55);
      border-radius: 20px;
      background: var(--surface);
      box-shadow: var(--shadow-sm);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .brand { display: flex; align-items: center; gap: 12px; min-width: 0; }
    .brand-mark {
      display: grid;
      place-items: center;
      width: 44px;
      height: 44px;
      flex: 0 0 auto;
      border-radius: 14px;
      color: #fff;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
      box-shadow: 0 10px 24px rgba(91,92,240,.28);
    }
    .brand-mark svg { width: 23px; height: 23px; }
    .brand-copy { min-width: 0; }
    .brand-copy strong { display: block; font-size: 15px; letter-spacing: -.01em; }
    .brand-copy span { display: block; margin-top: 2px; color: var(--muted); font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .top-actions { display: flex; align-items: center; gap: 8px; }
    .icon-btn {
      display: inline-grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border: 1px solid var(--line);
      border-radius: 13px;
      color: var(--text);
      background: var(--surface-solid);
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }
    .icon-btn:hover { transform: translateY(-1px); border-color: var(--primary); }
    .icon-btn svg { width: 19px; height: 19px; }

    .hero {
      position: relative;
      overflow: hidden;
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(260px, .65fr);
      gap: 24px;
      align-items: center;
      padding: 30px;
      border-radius: var(--radius-lg);
      color: #fff;
      background:
        linear-gradient(135deg, rgba(13,22,48,.12), rgba(13,22,48,.02)),
        linear-gradient(125deg, #5154ed 0%, #745be9 46%, #3b8af4 100%);
      box-shadow: 0 24px 60px rgba(57,65,180,.24);
    }
    .hero::before, .hero::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      background: rgba(255,255,255,.11);
      filter: blur(.2px);
    }
    .hero::before { width: 320px; height: 320px; right: -90px; top: -160px; }
    .hero::after { width: 180px; height: 180px; left: 46%; bottom: -130px; }
    .hero-copy, .hero-side { position: relative; z-index: 1; }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin-bottom: 12px;
      padding: 6px 10px;
      border: 1px solid rgba(255,255,255,.22);
      border-radius: 999px;
      background: rgba(255,255,255,.12);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .hero h1 { margin: 0; font-size: clamp(28px, 4vw, 48px); line-height: 1.06; letter-spacing: -.045em; }
    .hero p { max-width: 850px; margin: 13px 0 0; color: rgba(255,255,255,.86); line-height: 1.75; }
    .hero-side {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .hero-chip {
      padding: 14px;
      border: 1px solid rgba(255,255,255,.18);
      border-radius: 16px;
      background: rgba(255,255,255,.11);
      backdrop-filter: blur(12px);
    }
    .hero-chip small { display: block; color: rgba(255,255,255,.70); font-size: 11px; }
    .hero-chip strong { display: block; margin-top: 5px; font-size: 14px; }

    .workspace {
      display: grid;
      grid-template-columns: minmax(340px, .72fr) minmax(0, 1.55fr);
      gap: 18px;
      margin-top: 18px;
      align-items: start;
    }

    .panel {
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--surface);
      box-shadow: var(--shadow-md);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }
    .input-panel { position: sticky; top: 14px; overflow: hidden; }
    .panel-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 22px;
      border-bottom: 1px solid var(--line);
    }
    .panel-title { margin: 0; font-size: 18px; letter-spacing: -.02em; }
    .panel-subtitle { margin: 5px 0 0; color: var(--muted); font-size: 12.5px; line-height: 1.55; }
    .panel-body { padding: 20px 22px 22px; }

    .drop-zone {
      position: relative;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
      padding: 13px;
      border: 1px dashed var(--line-strong);
      border-radius: 14px;
      background: var(--surface-muted);
      transition: border-color .18s ease, background .18s ease, transform .18s ease;
    }
    .drop-zone.dragging { border-color: var(--primary); background: var(--primary-soft); transform: scale(1.005); }
    .drop-icon {
      display: grid;
      place-items: center;
      width: 40px;
      height: 40px;
      flex: 0 0 auto;
      border-radius: 12px;
      color: var(--primary);
      background: var(--primary-soft);
    }
    .drop-icon svg { width: 20px; height: 20px; }
    .drop-copy { min-width: 0; }
    .drop-copy strong { display: block; font-size: 13px; }
    .drop-copy span { display: block; margin-top: 3px; color: var(--muted); font-size: 11.5px; }
    #fileInput { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }

    .field-label { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 0 0 8px; font-size: 12.5px; font-weight: 800; }
    .field-label span:last-child { color: var(--muted); font-weight: 600; }
    textarea {
      width: 100%;
      min-height: 360px;
      resize: vertical;
      padding: 15px;
      border: 1px solid var(--line-strong);
      border-radius: 15px;
      outline: none;
      color: var(--text);
      background: var(--surface-solid);
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 12.2px;
      line-height: 1.6;
      transition: border-color .18s ease, box-shadow .18s ease;
    }
    textarea:focus, input:focus, select:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(91,92,240,.12); }

    .helper-box {
      display: flex;
      gap: 10px;
      margin-top: 11px;
      padding: 11px 12px;
      border: 1px solid var(--line);
      border-radius: 13px;
      color: var(--muted);
      background: var(--surface-muted);
      font-size: 11.5px;
      line-height: 1.55;
    }
    .helper-box svg { width: 17px; height: 17px; flex: 0 0 auto; color: var(--info); }

    .actions { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin-top: 14px; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 42px;
      border: 0;
      border-radius: 12px;
      padding: 10px 14px;
      font-weight: 800;
      transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    }
    .btn:hover { transform: translateY(-1px); }
    .btn svg { width: 17px; height: 17px; }
    .btn-primary { grid-column: 1 / -1; color: #fff; background: linear-gradient(135deg, var(--primary), var(--primary-2)); box-shadow: 0 10px 22px rgba(91,92,240,.24); }
    .btn-primary:hover { filter: brightness(1.04); box-shadow: 0 13px 28px rgba(91,92,240,.31); }
    .btn-secondary { color: var(--primary); background: var(--primary-soft); }
    .btn-muted { color: var(--text); background: var(--surface-muted); border: 1px solid var(--line); }
    .btn-danger-soft { color: var(--danger); background: var(--danger-soft); }

    .status-message {
      display: none;
      margin-top: 12px;
      padding: 11px 12px;
      border-radius: 12px;
      font-size: 12px;
      line-height: 1.55;
    }
    .status-message.show { display: block; }
    .status-message.success { color: var(--success); background: var(--success-soft); border: 1px solid color-mix(in srgb, var(--success) 24%, transparent); }
    .status-message.error { color: var(--danger); background: var(--danger-soft); border: 1px solid color-mix(in srgb, var(--danger) 24%, transparent); }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 11px;
      margin-bottom: 16px;
    }
    .stat-card {
      position: relative;
      overflow: hidden;
      min-height: 104px;
      padding: 15px 16px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: linear-gradient(180deg, var(--surface-solid), var(--surface-muted));
    }
    .stat-card::after {
      content: "";
      position: absolute;
      width: 74px;
      height: 74px;
      right: -28px;
      bottom: -32px;
      border-radius: 50%;
      background: var(--primary-soft);
    }
    .stat-icon {
      display: grid;
      place-items: center;
      width: 32px;
      height: 32px;
      margin-bottom: 10px;
      border-radius: 10px;
      color: var(--primary);
      background: var(--primary-soft);
    }
    .stat-icon svg { width: 16px; height: 16px; }
    .stat-card span { display: block; color: var(--muted); font-size: 11px; }
    .stat-card strong { position: relative; z-index: 1; display: block; margin-top: 4px; font-size: 21px; letter-spacing: -.03em; }

    .toolbar {
      display: grid;
      grid-template-columns: auto minmax(240px, 1fr) auto auto;
      gap: 9px;
      align-items: center;
      margin-bottom: 13px;
    }
    .control {
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 42px;
      padding: 0 11px;
      border: 1px solid var(--line-strong);
      border-radius: 12px;
      background: var(--surface-solid);
    }
    .control svg { width: 17px; height: 17px; color: var(--muted); flex: 0 0 auto; }
    .control input, .control select {
      width: 100%;
      height: 40px;
      border: 0;
      outline: 0;
      color: var(--text);
      background: transparent;
    }
    .control select { min-width: 100px; }
    .compact-btn {
      min-height: 42px;
      padding: 0 13px;
      border: 1px solid var(--line-strong);
      border-radius: 12px;
      color: var(--text);
      background: var(--surface-solid);
      font-size: 12px;
      font-weight: 800;
    }
    .compact-btn:hover { border-color: var(--primary); color: var(--primary); }

    .narrative-banner {
      display: none;
      gap: 12px;
      margin-bottom: 13px;
      padding: 13px 14px;
      border: 1px solid color-mix(in srgb, var(--primary) 20%, var(--line));
      border-radius: 14px;
      background: linear-gradient(135deg, var(--primary-soft), var(--surface-muted));
    }
    .narrative-banner.show { display: flex; }
    .narrative-icon {
      display: grid;
      place-items: center;
      width: 38px;
      height: 38px;
      flex: 0 0 auto;
      border-radius: 12px;
      color: var(--primary);
      background: var(--surface-solid);
      box-shadow: var(--shadow-sm);
    }
    .narrative-banner strong { display: block; margin-bottom: 4px; font-size: 12px; }
    .narrative-banner p { margin: 0; color: var(--muted); font-size: 12px; line-height: 1.6; }

    .table-wrap {
      width: 100%;
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--surface-solid);
      scrollbar-color: var(--line-strong) transparent;
    }
    table { width: 100%; min-width: 1160px; border-collapse: separate; border-spacing: 0; font-size: 12.5px; }
    th, td { padding: 14px 13px; vertical-align: top; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    th:last-child, td:last-child { border-right: 0; }
    tbody tr:last-child td { border-bottom: 0; }
    th {
      position: sticky;
      top: 0;
      z-index: 3;
      color: var(--text);
      background: var(--surface-muted);
      text-align: center;
      font-size: 11px;
      letter-spacing: .045em;
      text-transform: uppercase;
    }
    tbody tr { transition: background .18s ease; }
    tbody tr:hover td { background: color-mix(in srgb, var(--primary-soft) 34%, var(--surface-solid)); }

    .info-cell { min-width: 170px; text-align: center; line-height: 1.65; }
    .ticket-id { font-size: 13px; font-weight: 900; color: var(--text); word-break: break-word; }
    .member-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin: 6px 0;
      padding: 4px 8px;
      border-radius: 999px;
      color: var(--success);
      background: var(--success-soft);
      font-size: 10.5px;
      font-weight: 850;
    }
    .info-muted { color: var(--muted); font-size: 11.5px; }

    .selection-cell { min-width: 470px; }
    .selection-item {
      position: relative;
      margin-bottom: 10px;
      padding: 12px 12px 12px 42px;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: var(--surface-muted);
    }
    .selection-item:last-of-type { margin-bottom: 9px; }
    .selection-number {
      position: absolute;
      left: 11px;
      top: 11px;
      display: grid;
      place-items: center;
      width: 22px;
      height: 22px;
      border-radius: 8px;
      color: #fff;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
      font-size: 10px;
      font-weight: 900;
    }
    .selection-title { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; margin-bottom: 7px; font-weight: 900; color: var(--text); }
    .odd-pill { flex: 0 0 auto; padding: 4px 7px; border-radius: 999px; color: var(--primary); background: var(--primary-soft); font-size: 10px; font-weight: 900; }
    .selection-meta { display: grid; grid-template-columns: 86px minmax(0, 1fr); gap: 6px; margin-top: 4px; color: var(--muted); line-height: 1.45; }
    .selection-meta b { color: var(--text); font-weight: 800; }
    .selection-explain { margin-top: 8px; padding: 8px 9px; border-left: 3px solid var(--primary); border-radius: 8px; color: var(--muted); background: var(--surface-solid); line-height: 1.52; }
    .selection-explain b { color: var(--primary); }
    .row-actions { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 9px; }
    .link-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 0;
      border-radius: 9px;
      padding: 7px 10px;
      color: var(--primary);
      background: var(--primary-soft);
      font-size: 11px;
      font-weight: 850;
    }
    .link-btn:hover { filter: brightness(.98); }

    .center-cell { text-align: center; vertical-align: middle; line-height: 1.7; white-space: nowrap; }
    .value-strong { font-size: 14px; font-weight: 900; }
    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 10.5px;
      font-weight: 900;
      white-space: nowrap;
    }
    .badge::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .badge.pending { color: var(--warning); background: var(--warning-soft); }
    .badge.live { color: var(--info); background: var(--info-soft); }
    .badge.won { color: var(--success); background: var(--success-soft); }
    .badge.lost { color: var(--danger); background: var(--danger-soft); }
    .badge.neutral { color: var(--muted); background: var(--surface-muted); }

    .pagination-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 13px;
      color: var(--muted);
      font-size: 11.5px;
    }
    .pagination { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .page-btn {
      min-width: 34px;
      height: 34px;
      padding: 0 10px;
      border: 1px solid var(--line);
      border-radius: 10px;
      color: var(--text);
      background: var(--surface-solid);
      font-size: 11px;
      font-weight: 800;
    }
    .page-btn.active { color: #fff; border-color: var(--primary); background: linear-gradient(135deg, var(--primary), var(--primary-2)); }
    .page-btn:disabled { cursor: not-allowed; opacity: .45; }
    .empty-state { padding: 58px 20px !important; color: var(--muted); text-align: center; line-height: 1.75; }
    .empty-icon { display: grid; place-items: center; width: 54px; height: 54px; margin: 0 auto 12px; border-radius: 17px; color: var(--primary); background: var(--primary-soft); }
    .empty-icon svg { width: 26px; height: 26px; }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
      background: rgba(8,14,26,.66);
      backdrop-filter: blur(7px);
      -webkit-backdrop-filter: blur(7px);
    }
    .modal-backdrop.open { display: flex; }
    .modal {
      width: min(980px, 100%);
      max-height: 92vh;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--surface-solid);
      box-shadow: var(--shadow-lg);
      animation: modalIn .22s ease;
    }
    @keyframes modalIn { from { opacity: 0; transform: translateY(10px) scale(.985); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .modal-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 17px 19px; border-bottom: 1px solid var(--line); }
    .modal-header h3 { margin: 0; font-size: 18px; letter-spacing: -.02em; }
    .modal-header p { margin: 4px 0 0; color: var(--muted); font-size: 11.5px; }
    .modal-close { display: grid; place-items: center; width: 38px; height: 38px; border: 1px solid var(--line); border-radius: 11px; color: var(--text); background: var(--surface-muted); font-size: 21px; }
    .modal-body { max-height: calc(92vh - 135px); overflow: auto; padding: 19px; }
    .detail-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 9px; margin-bottom: 14px; }
    .detail-box { padding: 11px 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface-muted); }
    .detail-box small { display: block; margin-bottom: 5px; color: var(--muted); font-size: 10.5px; }
    .detail-box strong { display: block; font-size: 12.5px; word-break: break-word; }
    .full-sentence { margin-bottom: 14px; padding: 14px; border: 1px solid color-mix(in srgb, var(--primary) 24%, var(--line)); border-radius: 14px; background: linear-gradient(135deg, var(--primary-soft), var(--surface-muted)); }
    .full-sentence strong { display: block; margin-bottom: 6px; color: var(--primary); font-size: 12px; }
    .full-sentence p { margin: 0; color: var(--text); font-size: 12.5px; line-height: 1.7; }
