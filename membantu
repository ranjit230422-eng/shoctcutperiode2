    function firstValue(object, keys, fallback = "-") {
      for (const key of keys) {
        const value = object?.[key];
        if (value !== undefined && value !== null && value !== "") return value;
      }
      return fallback;
    }

    function toNumber(value, fallback = 0) {
      const number = Number(value);
      return Number.isFinite(number) ? number : fallback;
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatNumber(value, decimals = 3) {
      const number = Number(value);
      if (!Number.isFinite(number)) return "-";
      return number.toLocaleString("id-ID", {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals
      });
    }

    function formatMoney(value) {
      if (value === "-" || value === "" || value === null || value === undefined) return "-";
      const number = Number(value);
      return Number.isFinite(number)
        ? number.toLocaleString("id-ID", { maximumFractionDigits: 6 })
        : String(value);
    }

    function formatMatchDate(value) {
      if (!value || value === "-") return "-";
      const text = String(value).trim();
      const unusual = text.match(/^(\d{4})\s+(\d{2})\s+(\d{2})T(\d{2}):(\d{2})(?::(\d{2})(?:\.\d+)?)?\s*([+-]?\d{2}:\d{2})?$/);
      if (unusual) {
        const [, year, month, day, hour, minute, , rawZone] = unusual;
        const zone = rawZone ? (rawZone.startsWith("+") || rawZone.startsWith("-") ? rawZone : `+${rawZone}`) : "";
        return `${day}/${month}/${year} ${hour}:${minute}${zone ? ` (UTC${zone})` : ""}`;
      }
      const date = new Date(text);
      if (!Number.isNaN(date.getTime())) {
        return new Intl.DateTimeFormat("id-ID", {
          day: "2-digit", month: "2-digit", year: "numeric",
          hour: "2-digit", minute: "2-digit"
        }).format(date);
      }
      return text;
    }

    function extractJsonObjects(text) {
      const results = [];
      let depth = 0, start = -1, inString = false, escaped = false;
      for (let i = 0; i < text.length; i++) {
        const char = text[i];
        if (inString) {
          if (escaped) escaped = false;
          else if (char === "\\") escaped = true;
          else if (char === '"') inString = false;
          continue;
        }
        if (char === '"') { inString = true; continue; }
        if (char === "{") { if (depth === 0) start = i; depth++; }
        else if (char === "}") {
          depth--;
          if (depth === 0 && start >= 0) {
            try { results.push(JSON.parse(text.slice(start, i + 1))); } catch (_) {}
            start = -1;
          }
        }
      }
      return results;
    }

    function isSelectionObject(item) {
      if (!item || typeof item !== "object" || Array.isArray(item)) return false;
      return ["homeName", "awayName", "betChoice", "matchId", "leagueName", "odds"].some(key => key in item);
    }

    function findSelections(source) {
      const keys = ["selections", "selection", "items", "details", "bets", "betDetails", "legs", "matches"];
      for (const key of keys) if (Array.isArray(source?.[key])) return source[key];
      return isSelectionObject(source) ? [source] : [];
    }

    function parseInput(text) {
      const trimmed = text.trim();
      if (!trimmed) throw new Error("Data masih kosong. Silakan tempel JSON terlebih dahulu.");
      let parsed;
      try { parsed = JSON.parse(trimmed); }
      catch (_) {
        parsed = extractJsonObjects(trimmed);
        if (!parsed.length) throw new Error("JSON tidak dapat dibaca. Periksa tanda kurung, koma, dan tanda kutip.");
      }
      if (!Array.isArray(parsed)) parsed = [parsed];

      const ticketLike = parsed.filter(item => findSelections(item).length && !isSelectionObject(item));
      if (ticketLike.length) return ticketLike;

      const directSelections = parsed.filter(isSelectionObject);
      if (directSelections.length) {
        return [{
          ticketId: "-", username: "-", currency: "IDR",
          selections: directSelections, rawImportedData: parsed
        }];
      }

      const nested = parsed.flatMap(item => Array.isArray(item) ? item : []);
      if (nested.length) return nested;
      throw new Error("Data ditemukan, tetapi pilihan pertandingan tidak dikenali.");
    }

    function selectionStatus(raw) {
      const explicit = firstValue(raw, ["status", "resultStatus", "betStatus", "settlementStatus"], "");
      if (explicit) return String(explicit);
      if (raw.isLive === true) return "Sedang Berlangsung";
      return "Belum Dimulai";
