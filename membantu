    function explainSelection(selection) {
      const team = String(selection.betTeam ?? "").toLowerCase();
      const market = String(selection.market ?? "").toLowerCase();
      if (market.includes("1x2")) {
        if (team === "1") return `Tim kandang ${selection.home} dipilih untuk menang setelah waktu normal.`;
        if (team === "x") return "Pertandingan dipilih berakhir seri setelah waktu normal.";
        if (team === "2") return `Tim tandang ${selection.away} dipilih untuk menang setelah waktu normal.`;
      }
      if (market.includes("handicap")) {
        const point = selection.point && selection.point !== "-" ? ` dengan handicap ${selection.point}` : "";
        return `${selection.choice} dipilih pada pasaran handicap${point}.`;
      }
      if (market.includes("over/under") || market.includes("over under") || market.includes("total")) {
        const point = selection.point && selection.point !== "-" ? ` pada batas ${selection.point}` : "";
        return `${selection.choice} dipilih pada pasaran total gol${point}.`;
      }
      return `${selection.choice} dipilih pada pasaran ${selection.market}.`;
    }

