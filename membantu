        number: index + 1,
        matchId: firstValue(raw, ["matchId", "eventId", "fixtureId"], "-"),
        oddsId: firstValue(raw, ["oddsId", "selectionId"], "-"),
        home: firstValue(raw, ["homeName", "homeName_en", "home", "homeTeam"], "Tim Kandang"),
        away: firstValue(raw, ["awayName", "awayName_en", "away", "awayTeam"], "Tim Tandang"),
        league: firstValue(raw, ["leagueName", "leagueName_en", "competition", "league"], "-"),
        market: firstValue(raw, ["betTypeName", "betTypeName_en", "marketName", "market"], "-"),
        choice: firstValue(raw, ["betChoice", "betChoice_en", "selectionName", "choice"], "-"),
        odds: toNumber(firstValue(raw, ["odds", "price"], 0), 0),
        point: firstValue(raw, ["point", "line", "handicap"], "-"),
        betTeam: firstValue(raw, ["betTeam", "side"], "-"),
        date: formatMatchDate(firstValue(raw, ["matchDateTime", "kickOffTime", "eventTime", "startTime"], "-")),
        status: selectionStatus(raw),
        homeScore: firstValue(raw, ["homeScore", "scoreHome"], 0),
        awayScore: firstValue(raw, ["awayScore", "scoreAway"], 0),
        halfTimeScore: firstValue(raw, ["halfTimeScore", "htScore"], "-"),
        raw
      };
      selection.explanation = explainSelection(selection);
      return selection;
    }

    function normalizeStatus(value, selections) {
      const explicit = String(value ?? "").trim();
      if (explicit && explicit !== "-") return explicit;
      if (selections.some(item => item.status.toLowerCase().includes("berlangsung"))) return "Sedang Berlangsung";
      return "Menunggu Hasil";
    }

    function buildSearchText(ticket) {
      return [
        ticket.ticketId, ticket.username, ticket.date, ticket.currency, ticket.stake,
        ticket.actualStake, ticket.totalOdds, ticket.status, ticket.memberWinlose, ticket.ip,
        ...ticket.selections.flatMap(item => [
          item.matchId, item.oddsId, item.home, item.away, item.league, item.market,
          item.choice, item.odds, item.date, item.status, item.explanation
        ])
      ].join(" ").toLowerCase();
    }

    function normalizeTicket(raw, index) {
      const selections = findSelections(raw).map(normalizeSelection);
      const calculatedOdds = selections.reduce((total, item) => total * (item.odds || 1), selections.length ? 1 : 0);
      const suppliedOdds = toNumber(firstValue(raw, ["totalOdds", "parlayOdds", "oddsTotal"], 0), 0);
      const ticket = {
        _idx: index,
        ticketId: firstValue(raw, ["ticketId", "betId", "orderId", "referenceId", "transactionId", "id"], "-"),
        username: firstValue(raw, ["username", "member", "memberName", "user", "account"], "-"),
        date: formatMatchDate(firstValue(raw, ["betDate", "createdAt", "transactionDate", "date", "placedAt"], "-")),
        currency: firstValue(raw, ["currency", "currencyCode"], "IDR"),
        stake: firstValue(raw, ["stake", "betAmount", "amount"], "-"),
        actualStake: firstValue(raw, ["actualStake", "validStake", "turnover"], "-"),
        totalOdds: suppliedOdds || calculatedOdds,
        status: "",
        memberWinlose: firstValue(raw, ["memberWinlose", "winlose", "netWin", "profitLoss"], "-"),
        ip: firstValue(raw, ["ip", "ipAddress", "loginIp"], "-"),
        selections,
        raw
      };
      ticket.status = normalizeStatus(firstValue(raw, ["status", "betStatus", "settlementStatus"], ""), selections);
      ticket.searchText = buildSearchText(ticket);
      return ticket;
    }

    function statusClass(status) {
      const value = String(status).toLowerCase();
      if (value.includes("won") || value.includes("menang")) return "won";
      if (value.includes("lose") || value.includes("lost") || value.includes("kalah")) return "lost";
      if (value.includes("live") || value.includes("berlangsung")) return "live";
      if (value.includes("pending") || value.includes("menunggu") || value.includes("belum")) return "pending";
      return "neutral";
    }

    function combinedSentence(ticket) {
      const parts = ticket.selections.map(selection => {
        const market = String(selection.market).toLowerCase();
        const team = String(selection.betTeam).toLowerCase();
        if (market.includes("1x2")) {
          if (team === "1") return `${selection.home} dipilih menang melawan ${selection.away} dengan odds ${formatNumber(selection.odds, 2)}`;
          if (team === "x") return `${selection.home} melawan ${selection.away} dipilih berakhir seri dengan odds ${formatNumber(selection.odds, 2)}`;
          if (team === "2") return `${selection.away} dipilih menang melawan ${selection.home} dengan odds ${formatNumber(selection.odds, 2)}`;
        }
        return `${selection.choice} dipilih pada pertandingan ${selection.home} melawan ${selection.away} dengan odds ${formatNumber(selection.odds, 2)}`;
      });
      const type = ticket.selections.length > 1 ? "parlay" : "single";
      return `Tiket ${type} ini memiliki ${ticket.selections.length} pilihan: ${parts.join("; ")}. Total odds ${formatNumber(ticket.totalOdds, 3)}${ticket.stake !== "-" ? ` dengan stake ${formatMoney(ticket.stake)} ${ticket.currency}` : ""}.`;
    }

    function showMessage(message, type) {
      el.statusMessage.textContent = message;
      el.statusMessage.className = `status-message show ${type}`;
    }
    function clearMessage() {
      el.statusMessage.textContent = "";
      el.statusMessage.className = "status-message";
    }
    function showToast(message) {
      el.toastText.textContent = message;
      el.toast.classList.add("show");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => el.toast.classList.remove("show"), 1800);
    }

    function processData() {
      try {
        const rawTickets = parseInput(el.jsonInput.value);
        state.tickets = rawTickets.map(normalizeTicket).filter(ticket => ticket.selections.length);
        if (!state.tickets.length) throw new Error("Tidak ada pilihan pertandingan yang dapat ditampilkan.");
        state.page = 1;
        el.searchInput.value = "";
        el.statusFilter.value = "";
        applyFilter();
        const choices = state.tickets.reduce((sum, ticket) => sum + ticket.selections.length, 0);
        showMessage(`${state.tickets.length} tiket dan ${choices} pilihan berhasil diproses.`, "success");
      } catch (error) {
        state.tickets = [];
        state.filtered = [];
        renderAll();
        showMessage(error.message || "Terjadi kesalahan saat memproses data.", "error");
      }
    }

    function applyFilter() {
      const keyword = el.searchInput.value.trim().toLowerCase();
      const statusValue = el.statusFilter.value;
      state.filtered = state.tickets.filter(ticket => {
        const matchesKeyword = !keyword || ticket.searchText.includes(keyword);
        const matchesStatus = !statusValue || statusClass(ticket.status) === statusValue;
        return matchesKeyword && matchesStatus;
      });
      const totalPages = Math.max(1, Math.ceil(state.filtered.length / state.pageSize));
      if (state.page > totalPages) state.page = totalPages;
      renderAll();
    }

    function renderAll() {
      renderStats();
      renderNarrative();
      renderTable();
      renderPagination();
    }

    function renderStats() {
      const selectionCount = state.filtered.reduce((sum, ticket) => sum + ticket.selections.length, 0);
      const totalOdds = state.filtered.reduce((sum, ticket) => sum + ticket.totalOdds, 0);
      const totalStake = state.filtered.reduce((sum, ticket) => sum + (Number(ticket.stake) || 0), 0);
      el.statTickets.textContent = state.filtered.length.toLocaleString("id-ID");
      el.statSelections.textContent = selectionCount.toLocaleString("id-ID");
      el.statOdds.textContent = formatNumber(totalOdds, 3);
      el.statStake.textContent = totalStake.toLocaleString("id-ID", { maximumFractionDigits: 6 });
    }

    function renderNarrative() {
      if (state.filtered.length === 1) {
        el.narrativeBanner.classList.add("show");
        el.narrativeText.textContent = combinedSentence(state.filtered[0]);
      } else if (state.filtered.length > 1) {
        el.narrativeBanner.classList.add("show");
        el.narrativeText.textContent = `Terdapat ${state.filtered.length} tiket yang sesuai filter dengan total ${state.filtered.reduce((sum, t) => sum + t.selections.length, 0)} pilihan.`;
      } else {
        el.narrativeBanner.classList.remove("show");
        el.narrativeText.textContent = "";
      }
    }

    function renderSelectionHtml(selection) {
      return `
        <div class="selection-item">
          <div class="selection-number">${selection.number}</div>
          <div class="selection-title">
            <span>${escapeHtml(selection.choice)}</span>
            <span class="odd-pill">@${formatNumber(selection.odds, 2)}</span>
          </div>
          <div class="selection-meta"><b>Pasaran</b><span>${escapeHtml(selection.market)}</span></div>
          <div class="selection-meta"><b>Laga</b><span>${escapeHtml(selection.home)} vs ${escapeHtml(selection.away)}</span></div>
          <div class="selection-meta"><b>Liga</b><span>${escapeHtml(selection.league)}</span></div>
          <div class="selection-meta"><b>Jadwal</b><span>${escapeHtml(selection.date)}</span></div>
          <div class="selection-meta"><b>Status</b><span>${escapeHtml(selection.status)} · Skor ${escapeHtml(selection.homeScore)} : ${escapeHtml(selection.awayScore)}</span></div>
          <div class="selection-explain"><b>Artinya:</b> ${escapeHtml(selection.explanation)}</div>
        </div>`;
    }

    function renderTable() {
      if (!state.filtered.length) {
        el.tableBody.innerHTML = `
          <tr><td colspan="8" class="empty-state">
            <div class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 4h14v16H5zM8 8h8M8 12h8M8 16h5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            Belum ada data yang ditampilkan.<br>Muat contoh atau tempel JSON, lalu klik <b>Proses dan Tampilkan</b>.
          </td></tr>`;
        el.entryInfo.textContent = "Showing 0 to 0 of 0 entries";
        return;
      }

      const start = (state.page - 1) * state.pageSize;
      const end = Math.min(start + state.pageSize, state.filtered.length);
      const pageItems = state.filtered.slice(start, end);

      el.tableBody.innerHTML = pageItems.map(ticket => {
        const information = `
          <div class="info-cell">
            <div class="ticket-id">${escapeHtml(ticket.ticketId)}</div>
            ${ticket.username !== "-" ? `<div class="member-badge">● ${escapeHtml(ticket.username)}</div>` : ""}
            <div class="info-muted">${escapeHtml(ticket.date)}</div>
            <div class="info-muted">${ticket.selections.length} pilihan · ${ticket.selections.length > 1 ? "Parlay" : "Single"}</div>
          </div>`;
        const selections = ticket.selections.map(renderSelectionHtml).join("");
        return `
          <tr>
            <td>${information}</td>
            <td class="selection-cell">
              ${selections}
              <div class="row-actions">
                <button class="link-btn" onclick="openDetails(${ticket._idx})">Lihat Details →</button>
                <button class="link-btn" onclick="copyTicketSentence(${ticket._idx})">Salin Kalimat</button>
              </div>
            </td>
            <td class="center-cell">${escapeHtml(ticket.currency)}</td>
            <td class="center-cell">${escapeHtml(formatMoney(ticket.stake))}<br><span class="info-muted">${escapeHtml(formatMoney(ticket.actualStake))}</span></td>
            <td class="center-cell"><span class="value-strong">${formatNumber(ticket.totalOdds, 3)}</span></td>
            <td class="center-cell"><span class="badge ${statusClass(ticket.status)}">${escapeHtml(ticket.status)}</span></td>
            <td class="center-cell">${escapeHtml(formatMoney(ticket.memberWinlose))}</td>
            <td class="center-cell">${escapeHtml(ticket.ip)}</td>
          </tr>`;
      }).join("");
      el.entryInfo.textContent = `Showing ${start + 1} to ${end} of ${state.filtered.length} entries`;
    }

    function renderPagination() {
      const totalPages = Math.max(1, Math.ceil(state.filtered.length / state.pageSize));
      if (!state.filtered.length) { el.pagination.innerHTML = ""; return; }
      const buttons = [];
      buttons.push(`<button class="page-btn" ${state.page === 1 ? "disabled" : ""} onclick="changePage(${state.page - 1})">Previous</button>`);
      const startPage = Math.max(1, state.page - 2);
      const endPage = Math.min(totalPages, state.page + 2);
      if (startPage > 1) {
        buttons.push(`<button class="page-btn" onclick="changePage(1)">1</button>`);
        if (startPage > 2) buttons.push(`<span>…</span>`);
      }
      for (let page = startPage; page <= endPage; page++) {
        buttons.push(`<button class="page-btn ${page === state.page ? "active" : ""}" onclick="changePage(${page})">${page}</button>`);
      }
      if (endPage < totalPages) {
        if (endPage < totalPages - 1) buttons.push(`<span>…</span>`);
        buttons.push(`<button class="page-btn" onclick="changePage(${totalPages})">${totalPages}</button>`);
      }
      buttons.push(`<button class="page-btn" ${state.page === totalPages ? "disabled" : ""} onclick="changePage(${state.page + 1})">Next</button>`);
      el.pagination.innerHTML = buttons.join("");
    }

    function changePage(page) {
      const totalPages = Math.max(1, Math.ceil(state.filtered.length / state.pageSize));
      state.page = Math.min(Math.max(1, page), totalPages);
      renderTable();
      renderPagination();
    }

    function summaryText(ticket) {
      const lines = [
        "INFORMATION",
        `Ticket ID: ${ticket.ticketId}`,
        `Member: ${ticket.username}`,
        `Tanggal: ${ticket.date}`,
        `Jenis taruhan: ${ticket.selections.length > 1 ? "Parlay" : "Single"}`,
        `Jumlah pilihan: ${ticket.selections.length}`,
        "",
        "KALIMAT LENGKAP",
        combinedSentence(ticket),
        "",
        "SELECTION"
      ];
      ticket.selections.forEach(selection => {
        lines.push(
          "",
          `${selection.number}. ${selection.choice} @${formatNumber(selection.odds, 2)}`,
          `   Pertandingan: ${selection.home} vs ${selection.away}`,
          `   Pasaran: ${selection.market}`,
          `   Liga: ${selection.league}`,
          `   Jadwal: ${selection.date}`,
          `   Status: ${selection.status}`,
          `   Artinya: ${selection.explanation}`
        );
      });
      lines.push(
        "",
        `Currency: ${ticket.currency}`,
        `Stake: ${formatMoney(ticket.stake)}`,
        `Actual Stake: ${formatMoney(ticket.actualStake)}`,
        `Total Odds: ${formatNumber(ticket.totalOdds, 3)}`,
        `Status: ${ticket.status}`,
        `Member Winlose: ${formatMoney(ticket.memberWinlose)}`,
        `IP: ${ticket.ip}`
      );
      return lines.join("\n");
    }

    function openDetails(index) {
      const ticket = state.tickets.find(item => item._idx === index);
      if (!ticket) return;
      state.activeTicket = ticket;
      el.modalTitle.textContent = `Detail Tiket ${ticket.ticketId}`;
      const selectionDetails = ticket.selections.map(selection => `
        <div class="detail-selection">
          <div class="selection-number">${selection.number}</div>
          <b>${escapeHtml(selection.choice)} @${formatNumber(selection.odds, 2)}</b><br>
          ${escapeHtml(selection.home)} vs ${escapeHtml(selection.away)}<br>
          <span class="info-muted">Pasaran:</span> ${escapeHtml(selection.market)}<br>
          <span class="info-muted">Liga:</span> ${escapeHtml(selection.league)}<br>
          <span class="info-muted">Jadwal:</span> ${escapeHtml(selection.date)}<br>
          <span class="info-muted">Status:</span> ${escapeHtml(selection.status)}<br>
          <span class="info-muted">Penjelasan:</span> ${escapeHtml(selection.explanation)}
        </div>`).join("");

      el.modalBody.innerHTML = `
        <div class="detail-grid">
          <div class="detail-box"><small>Ticket ID</small><strong>${escapeHtml(ticket.ticketId)}</strong></div>
          <div class="detail-box"><small>Member</small><strong>${escapeHtml(ticket.username)}</strong></div>
          <div class="detail-box"><small>Total Odds</small><strong>${formatNumber(ticket.totalOdds, 3)}</strong></div>
          <div class="detail-box"><small>Status</small><strong>${escapeHtml(ticket.status)}</strong></div>
          <div class="detail-box"><small>Currency</small><strong>${escapeHtml(ticket.currency)}</strong></div>
          <div class="detail-box"><small>Stake</small><strong>${escapeHtml(formatMoney(ticket.stake))}</strong></div>
          <div class="detail-box"><small>Actual Stake</small><strong>${escapeHtml(formatMoney(ticket.actualStake))}</strong></div>
          <div class="detail-box"><small>IP</small><strong>${escapeHtml(ticket.ip)}</strong></div>
        </div>
        <div class="full-sentence"><strong>Kalimat Lengkap</strong><p>${escapeHtml(combinedSentence(ticket))}</p></div>
        ${selectionDetails}
        <h4 class="raw-title">Data JSON asli</h4>
        <pre>${escapeHtml(JSON.stringify(ticket.raw, null, 2))}</pre>`;
      el.modalBackdrop.classList.add("open");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      el.modalBackdrop.classList.remove("open");
      document.body.style.overflow = "";
    }

    async function copyText(text, message) {
      try {
        await navigator.clipboard.writeText(text);
      } catch (_) {
        const temp = document.createElement("textarea");
        temp.value = text;
        document.body.appendChild(temp);
        temp.select();
        document.execCommand("copy");
        temp.remove();
      }
      showToast(message);
    }

    function copyTicketSentence(index) {
      const ticket = state.tickets.find(item => item._idx === index);
      if (ticket) copyText(combinedSentence(ticket), "Kalimat lengkap berhasil disalin.");
    }

    function downloadFile(filename, content, type = "text/plain;charset=utf-8") {
      const blob = new Blob([content], { type });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    function csvEscape(value) {
      const text = String(value ?? "");
      return `"${text.replaceAll('"', '""')}"`;
    }

    function exportCsv() {
      if (!state.filtered.length) { showToast("Belum ada data untuk diekspor."); return; }
      const rows = [["Ticket ID","Member","Tanggal","Jenis","Jumlah Pilihan","Selection","Currency","Stake","Actual Stake","Total Odds","Status","Member Winlose","IP","Kalimat Lengkap"]];
      state.filtered.forEach(ticket => {
        const selections = ticket.selections.map(s => `${s.number}. ${s.choice} @${formatNumber(s.odds, 2)} | ${s.home} vs ${s.away} | ${s.market} | ${s.league}`).join(" || ");
        rows.push([
          ticket.ticketId, ticket.username, ticket.date,
          ticket.selections.length > 1 ? "Parlay" : "Single",
          ticket.selections.length, selections, ticket.currency, ticket.stake,
          ticket.actualStake, ticket.totalOdds, ticket.status, ticket.memberWinlose,
          ticket.ip, combinedSentence(ticket)
        ]);
      });
      downloadFile("hasil_informasi_details.csv", "\uFEFF" + rows.map(row => row.map(csvEscape).join(",")).join("\n"), "text/csv;charset=utf-8");
      showToast("CSV berhasil dibuat.");
    }

    function updateCharCount() {
      el.charCount.textContent = `${el.jsonInput.value.length.toLocaleString("id-ID")} karakter`;
    }

    function loadTheme() {
      const saved = localStorage.getItem("betslip-theme");
      const preferDark = window.matchMedia?.("(prefers-color-scheme: dark)").matches;
      const theme = saved || (preferDark ? "dark" : "light");
      document.documentElement.dataset.theme = theme;
      el.themeIcon.innerHTML = theme === "dark" ? ICONS.sun : ICONS.moon;
    }

    function toggleTheme() {
      const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("betslip-theme", next);
      el.themeIcon.innerHTML = next === "dark" ? ICONS.sun : ICONS.moon;
    }

    async function handleFile(file) {
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { showMessage("Ukuran file melebihi 5 MB.", "error"); return; }
      try {
        el.jsonInput.value = await file.text();
        updateCharCount();
        clearMessage();
        processData();
      } catch (_) {
        showMessage("File tidak dapat dibaca.", "error");
      }
    }

    el.processBtn.addEventListener("click", processData);
    el.sampleBtn.addEventListener("click", () => {
      el.jsonInput.value = JSON.stringify(SAMPLE_DATA, null, 2);
      updateCharCount();
      clearMessage();
      processData();
    });
    el.pasteBtn.addEventListener("click", async () => {
      try {
        el.jsonInput.value = await navigator.clipboard.readText();
        updateCharCount();
        clearMessage();
        showToast("Data clipboard berhasil ditempel.");
      } catch (_) {
        showMessage("Browser tidak mengizinkan membaca clipboard. Gunakan Ctrl+V pada kotak input.", "error");
      }
    });
    el.clearBtn.addEventListener("click", () => {
      el.jsonInput.value = "";
      el.searchInput.value = "";
      el.statusFilter.value = "";
      state.tickets = [];
      state.filtered = [];
      state.page = 1;
      updateCharCount();
      clearMessage();
      renderAll();
      el.jsonInput.focus();
    });
    el.downloadInputBtn.addEventListener("click", () => {
      if (!el.jsonInput.value.trim()) { showToast("Input masih kosong."); return; }
      downloadFile("data_taruhan.json", el.jsonInput.value, "application/json;charset=utf-8");
    });
    el.jsonInput.addEventListener("input", updateCharCount);
    el.fileInput.addEventListener("change", event => handleFile(event.target.files?.[0]));
    ["dragenter", "dragover"].forEach(type => el.dropZone.addEventListener(type, event => {
      event.preventDefault(); el.dropZone.classList.add("dragging");
    }));
    ["dragleave", "drop"].forEach(type => el.dropZone.addEventListener(type, event => {
      event.preventDefault(); el.dropZone.classList.remove("dragging");
    }));
    el.dropZone.addEventListener("drop", event => handleFile(event.dataTransfer.files?.[0]));
    el.searchInput.addEventListener("input", () => { state.page = 1; applyFilter(); });
    el.statusFilter.addEventListener("change", () => { state.page = 1; applyFilter(); });
    el.pageSize.addEventListener("change", () => {
      state.pageSize = Number(el.pageSize.value);
      state.page = 1;
      renderTable();
      renderPagination();
    });
    el.exportBtn.addEventListener("click", exportCsv);
    el.modalClose.addEventListener("click", closeModal);
    el.modalCloseBottom.addEventListener("click", closeModal);
    el.copyBtn.addEventListener("click", () => {
      if (state.activeTicket) copyText(summaryText(state.activeTicket), "Ringkasan berhasil disalin.");
    });
    el.copySentenceBtn.addEventListener("click", () => {
      if (state.activeTicket) copyText(combinedSentence(state.activeTicket), "Kalimat lengkap berhasil disalin.");
    });
    el.modalBackdrop.addEventListener("click", event => { if (event.target === el.modalBackdrop) closeModal(); });
    document.addEventListener("keydown", event => { if (event.key === "Escape") closeModal(); });
    el.themeBtn.addEventListener("click", toggleTheme);

    window.openDetails = openDetails;
    window.changePage = changePage;
    window.copyTicketSentence = copyTicketSentence;

    loadTheme();
    el.jsonInput.value = JSON.stringify(SAMPLE_DATA, null, 2);
    updateCharCount();
    processData();
  </script>
</body>
</html>
